# R2R Marketing Digital - Hostinger / Apache
DirectoryIndex index.html
Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# Forçar HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Manter domínio sem WWW
RewriteCond %{HTTP_HOST} ^www\.r2rmarketingdigital\.com\.br$ [NC]
RewriteRule ^(.*)$ https://r2rmarketingdigital.com.br/$1 [L,R=301]
</IfModule>

# Compressão
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/html "access plus 1 hour"
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

# Segurança básica
<IfModule mod_headers.c>
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Proteger arquivos sensíveis
<FilesMatch "^(\.htaccess|\.htpasswd|\.env|config|composer\.json|composer\.lock|package\.json|package-lock\.json)$">
Order allow,deny
Deny from all
</FilesMatch>
